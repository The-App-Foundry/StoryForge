#emptyStateWidget {
  border: 1.5px dashed rgba(68,76,86,0.9);
}

#startEditingBtn {
  background: transparent;
  border: 1px solid #444c56;
  border-radius: 0;
  margin-top: 20px;
  padding: 6px 16px;
  font-size: 10px;
  font-family: "DM MONO", monospace;
  color: #8b949e;
}

#startEditingBtn:hover {
  border-color: #ffffff;
  color: #ffffff;
}